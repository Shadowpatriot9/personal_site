# Copy to .env.local for local development. NEVER commit real secrets.
# In production these are set in the Vercel dashboard.

# --- Admin authentication (required in production) ---
# The admin login credentials. No hardcoded fallback ships in the code.
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password

# Optional: precomputed PBKDF2 hashes (hex, 64-byte). If set, these take
# precedence over ADMIN_USERNAME / ADMIN_PASSWORD above.
# ADMIN_USERNAME_HASH=
# ADMIN_PASSWORD_HASH=
# ADMIN_CREDENTIALS_SALT=change-me
# ADMIN_PBKDF2_ITERATIONS=150000

# --- JWT signing secrets (required in production) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
REFRESH_TOKEN_SECRET=
# ACCESS_TOKEN_EXPIRATION=15m
# REFRESH_TOKEN_EXPIRATION=7d

# --- Database (optional) ---
# Without MONGO_URI the admin panel uses a local file-backed store (.data/).
# Set it to use MongoDB instead (required for persistence on Vercel).
# MONGO_URI=

# --- Contact form email (optional) ---
# Without RESEND_API_KEY the contact form validates and accepts messages
# without sending. Set a Resend key (https://resend.com) to deliver them.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=gscovil9@gmail.com
# Verify a domain in Resend, then use it here (defaults to Resend's test sender).
# CONTACT_FROM_EMAIL=Portfolio <contact@mgds.me>
